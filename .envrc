# direnv：进入 aemeath 工作区（含任意 worktree）自动设置 CARGO_TARGET_DIR。
# 配合 .cargo/set-target.sh 按分支隔离 target，避免 worktree 间重复全量编译（#1226）。
#
# 使用前需安装并启用 direnv：
#   brew install direnv
#   # 按你的 shell 添加 hook（见 https://direnv.net/docs/hook.html），例如 zsh：
#   #   eval "$(direnv hook zsh)"
#   direnv allow
#
# 离开工作区时 direnv 自动卸载 CARGO_TARGET_DIR，不污染全局环境。

# 激活 set-target.sh 前，确认它在当前 worktree 根存在（worktree 共享仓库根文件）。
_self_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -f "$_self_dir/.cargo/set-target.sh" ]]; then
  # shellcheck source=/dev/null
  source "$_self_dir/.cargo/set-target.sh"
fi
unset _self_dir
