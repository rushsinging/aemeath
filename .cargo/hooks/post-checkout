#!/usr/bin/env bash
# post-checkout hook：为当前 checkout/worktree 生成本地 Cargo config。
# target-dir 使用“可读分支标签 + worktree 根路径哈希”，兼顾并行隔离与可诊断性。

set -euo pipefail

top="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
cd "$top"

script_dir="$top/.cargo"
[[ -f "$script_dir/lib.sh" ]] || exit 0
# shellcheck source=/dev/null
source "$script_dir/lib.sh"

cache_key="$(worktree_cache_key "$top")"
target_dir="${HOME}/.cache/aemeath-target/${cache_key}"
build_dir="${target_dir}/build"

cat > "$script_dir/config.toml" <<EOF
# AUTO-GENERATED by .cargo/hooks/post-checkout（worktree-local，gitignored）。
# 需要 Cargo 1.91+；target/build 目录按 checkout/worktree 隔离。
[build]
target-dir = "$target_dir"
build-dir = "$build_dir"
EOF
