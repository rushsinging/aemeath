{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit",
        "command": "\"{AEMEATH_PROJECT_DIR}/.agents/hooks/reject-main-edit.sh\"",
        "timeout": 10
      },
      {
        "matcher": "Write",
        "command": "\"{AEMEATH_PROJECT_DIR}/.agents/hooks/reject-main-edit.sh\"",
        "timeout": 10
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "command": "\"{AEMEATH_PROJECT_DIR}/.agents/hooks/check-architecture-guards.sh\"",
        "timeout": 120
      },
      {
        "matcher": "",
        "command": "\"{AEMEATH_PROJECT_DIR}/.agents/hooks/check-unit-tests.sh\"",
        "timeout": 600
      },
      {
        "matcher": "",
        "command": "\"{AEMEATH_PROJECT_DIR}/build_cli.sh\"",
        "timeout": 300
      }
    ]
  }
}
